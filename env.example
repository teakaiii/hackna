# Copy this file to ".env" in the project folder, then restart the server.
# Real Gmail notifications require a Google "App Password" (not your normal password).

# --- Public URL (used in email links — must match how you open the app)
PUBLIC_URL=http://localhost:3000

# --- Gmail (recommended)
# 1) Turn on 2-Step Verification: https://myaccount.google.com/security
# 2) Create App Password: https://myaccount.google.com/apppasswords  (pick "Mail" / "Other")
# 3) Paste the 16-character password below (spaces optional — they are stripped)

GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Same as above (supported for older configs)
# EMAIL_USER=youraddress@gmail.com
# EMAIL_PASS=your_16_char_app_password

# Optional: "From" header — defaults to GMAIL_USER if unset
# EMAIL_FROM=youraddress@gmail.com

# --- Alternative names (same as Gmail vars above)
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_app_password

# --- Custom SMTP (non-Gmail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false

# --- MySQL Database Configuration (Production)
# For InfinityFree deployment, use your InfinityFree MySQL credentials
DB_HOST=your_mysql_host.infinityfree.com
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# --- Gmail Email Service (Required for Email Notifications)
# 1. Enable 2-Step Verification on your Gmail
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use App Password below (not your regular password)

EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your_16_char_app_password
FROM_EMAIL=noreply@concerntrack.app

# --- Production Settings
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://if0_41647799.infinityfreeapp.com

# --- Resend Email Service (Real Email Sending)
# Get your API key from https://resend.com/
# 1. Create a free account
# 2. Get your API key from dashboard
# 3. Set your from email address
# 4. Real emails sent to any student email automatically

RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=jennypadillo90@gmail.com

# --- Dev only: fake inbox (does NOT deliver to real Gmail)
# USE_ETHEREAL_MAIL=true
